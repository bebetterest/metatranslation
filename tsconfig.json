{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["chrome", "node"],
    "verbatimModuleSyntax": true
  },
  "include": ["manifest.config.ts", "vite.config.ts", "src/**/*.ts"]
}
